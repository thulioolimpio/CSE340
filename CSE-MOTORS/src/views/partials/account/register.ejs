<%- include('../partials/header') %>

<style>
  /* ===== ESTILOS LOCAIS PARA REGISTRO ===== */
  .register-main {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f7fafc;
    padding: 2rem 1rem;
    min-height: 80vh;
  }

  .register-container {
    width: 100%;
    max-width: 500px;
    background: white;
    border-radius: 8px;
    box-shadow: 0 4px 6px rgba(0, 0, 0, 0.1);
    padding: 2rem;
    margin: 2rem auto;
  }

  .register-title {
    color: #2a4365;
    font-family: 'Poppins', sans-serif;
    text-align: center;
    margin-bottom: 1.5rem;
    font-size: 2rem;
    position: relative;
    padding-bottom: 0.5rem;
  }

  .register-title::after {
    content: '';
    display: block;
    width: 60px;
    height: 3px;
    background: #f6ad55;
    margin: 0.5rem auto 0;
  }

  .register-errors {
    background-color: #fee2e2;
    color: #b91c1c;
    padding: 1rem;
    border-radius: 4px;
    margin-bottom: 1.5rem;
    list-style: none;
  }

  .register-errors li {
    margin-bottom: 0.25rem;
    position: relative;
    padding-left: 1rem;
  }

  .register-errors li::before {
    content: '•';
    position: absolute;
    left: 0;
    color: #e53e3e;
  }

  .register-form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .form-group {
    margin-bottom: 1rem;
  }

  .form-group label {
    display: block;
    margin-bottom: 0.5rem;
    color: #2a4365;
    font-weight: 500;
    font-family: 'Inter', sans-serif;
  }

  .form-group input {
    width: 100%;
    padding: 0.75rem 1rem;
    border: 1px solid #e2e8f0;
    border-radius: 4px;
    font-family: 'Inter', sans-serif;
    font-size: 1rem;
    transition: all 0.3s;
  }

  .form-group input:focus {
    border-color: #2a4365;
    box-shadow: 0 0 0 3px rgba(42, 67, 101, 0.2);
    outline: none;
  }

  .register-button {
    background-color: #2a4365;
    color: white;
    padding: 0.75rem 1rem;
    border: none;
    border-radius: 4px;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.3s;
    margin-top: 1rem;
    font-family: 'Inter', sans-serif;
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    width: 100%;
  }

  .register-button:hover {
    background-color: #1e3a8a;
    transform: translateY(-2px);
  }

  .register-links {
    margin-top: 1.5rem;
    text-align: center;
    font-family: 'Inter', sans-serif;
    color: #4a5568;
  }

  .register-links a {
    color: #2a4365;
    text-decoration: none;
    transition: color 0.3s;
    font-weight: 500;
  }

  .register-links a:hover {
    color: #e53e3e;
    text-decoration: underline;
  }

  /* Responsividade */
  @media (max-width: 768px) {
    .register-container {
      padding: 1.5rem;
      margin: 1rem;
    }
    
    .register-title {
      font-size: 1.75rem;
    }
    
    .register-main {
      padding: 1rem;
      min-height: calc(100vh - 120px);
    }
  }
</style>

<main class="register-main">
  <div class="register-container">
    <h1 class="register-title">Registrar</h1>

    <% if (errors && errors.length) { %>
      <ul class="register-errors">
        <% errors.forEach(e => { %><li><%= e.msg %></li><% }) %>
      </ul>
    <% } %>

    <form class="register-form" action="/account/register" method="post">
      <div class="form-group">
        <label for="firstname">Nome</label>
        <input type="text" id="firstname" name="firstname" required>
      </div>

      <div class="form-group">
        <label for="lastname">Sobrenome</label>
        <input type="text" id="lastname" name="lastname" required>
      </div>

      <div class="form-group">
        <label for="email">Email</label>
        <input type="email" id="email" name="email" required>
      </div>

      <div class="form-group">
        <label for="password">Senha</label>
        <input type="password" id="password" name="password" required>
      </div>

      <button type="submit" class="register-button">Criar conta</button>
    </form>

    <div class="register-links">
      <a href="/account/login">Já tem uma conta? Faça login</a>
    </div>
  </div>
</main>

<%- include('partials/footer') %>