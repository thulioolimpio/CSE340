<%- include('../partials/head') %>
<%- include('../partials/header') %>
<%- include('../partials/nav') %>

<main class="container form-page">
  <h1 class="page-title">Add Vehicle</h1>
  
  <!-- Flash Messages -->
  <% if (locals.messages && Array.isArray(locals.messages) && locals.messages.length) { %>
    <% locals.messages.forEach(function(msg) { %>
      <div class="alert alert-<%= msg.type || 'info' %>">
        <%= msg.message || msg.msg || 'Operation completed' %>
      </div>
    <% }) %>
  <% } %>

  <!-- Error Messages -->
  <% if (locals.errors && Array.isArray(locals.errors) && locals.errors.length) { %>
    <div class="alert alert-danger">
      <ul class="mb-0">
        <% locals.errors.forEach(function(error) { %>
          <li><%= error.msg || error.message || error %></li>
        <% }) %>
      </ul>
    </div>
  <% } %>

  <form class="inventory-form" action="/inv/add-inventory" method="post" enctype="multipart/form-data">
    <!-- Classification -->
    <div class="form-group">
      <label for="classification_id">Classification *</label>
      <select id="classification_id" name="classification_id" class="form-control <%= locals.errors && locals.errors.some(e => e.param === 'classification_id') ? 'is-invalid' : '' %>" required>
        <option value="">Select a classification</option>
        <% if (locals.classifications && Array.isArray(locals.classifications) && locals.classifications.length) { %>
          <% locals.classifications.forEach(function(classification) { %>
            <option value="<%= classification.classification_id %>" 
              <% if (locals.formData && locals.formData.classification_id == classification.classification_id) { %>selected<% } %>>
              <%= classification.classification_name %>
            </option>
          <% }) %>
        <% } else { %>
          <option value="" disabled>No classifications available</option>
        <% } %>
      </select>
      <% if (locals.errors && locals.errors.some(e => e.param === 'classification_id')) { %>
        <div class="invalid-feedback">
          Please select a valid classification
        </div>
      <% } %>
    </div>

    <!-- Vehicle Make and Model -->
    <div class="form-row">
      <div class="form-group col-md-6">
        <label for="inv_make">Make *</label>
        <input type="text" id="inv_make" name="inv_make" 
               class="form-control <%= locals.errors && locals.errors.some(e => e.param === 'inv_make') ? 'is-invalid' : '' %>"
               value="<%= (locals.formData && locals.formData.inv_make) || '' %>" 
               minlength="3" required>
        <% if (locals.errors && locals.errors.some(e => e.param === 'inv_make')) { %>
          <div class="invalid-feedback">
            Make must be at least 3 characters
          </div>
        <% } %>
      </div>
      <div class="form-group col-md-6">
        <label for="inv_model">Model *</label>
        <input type="text" id="inv_model" name="inv_model" 
               class="form-control <%= locals.errors && locals.errors.some(e => e.param === 'inv_model') ? 'is-invalid' : '' %>"
               value="<%= (locals.formData && locals.formData.inv_model) || '' %>" 
               minlength="3" required>
        <% if (locals.errors && locals.errors.some(e => e.param === 'inv_model')) { %>
          <div class="invalid-feedback">
            Model must be at least 3 characters
          </div>
        <% } %>
      </div>
    </div>

    <!-- Year and Price -->
    <div class="form-row">
      <div class="form-group col-md-6">
        <label for="inv_year">Year *</label>
        <input type="number" id="inv_year" name="inv_year" min="1900" max="<%= new Date().getFullYear() + 1 %>" 
               class="form-control <%= locals.errors && locals.errors.some(e => e.param === 'inv_year') ? 'is-invalid' : '' %>"
               value="<%= (locals.formData && locals.formData.inv_year) || '' %>" required>
        <% if (locals.errors && locals.errors.some(e => e.param === 'inv_year')) { %>
          <div class="invalid-feedback">
            Please enter a valid year (1900-<%= new Date().getFullYear() + 1 %>)
          </div>
        <% } %>
      </div>
      <div class="form-group col-md-6">
        <label for="inv_price">Price ($) *</label>
        <input type="number" step="0.01" id="inv_price" name="inv_price" min="0" 
               class="form-control <%= locals.errors && locals.errors.some(e => e.param === 'inv_price') ? 'is-invalid' : '' %>"
               value="<%= (locals.formData && locals.formData.inv_price) || '' %>" required>
        <% if (locals.errors && locals.errors.some(e => e.param === 'inv_price')) { %>
          <div class="invalid-feedback">
            Price must be a positive number
          </div>
        <% } %>
      </div>
    </div>

    <!-- Miles and Color -->
    <div class="form-row">
      <div class="form-group col-md-6">
        <label for="inv_miles">Miles *</label>
        <input type="number" id="inv_miles" name="inv_miles" min="0" 
               class="form-control <%= locals.errors && locals.errors.some(e => e.param === 'inv_miles') ? 'is-invalid' : '' %>"
               value="<%= (locals.formData && locals.formData.inv_miles) || '' %>" required>
        <% if (locals.errors && locals.errors.some(e => e.param === 'inv_miles')) { %>
          <div class="invalid-feedback">
            Mileage must be a positive number
          </div>
        <% } %>
      </div>
      <div class="form-group col-md-6">
        <label for="inv_color">Color *</label>
        <input type="text" id="inv_color" name="inv_color" 
               class="form-control <%= locals.errors && locals.errors.some(e => e.param === 'inv_color') ? 'is-invalid' : '' %>"
               value="<%= (locals.formData && locals.formData.inv_color) || '' %>" required>
        <% if (locals.errors && locals.errors.some(e => e.param === 'inv_color')) { %>
          <div class="invalid-feedback">
            Color is required
          </div>
        <% } %>
      </div>
    </div>

    <!-- Images -->
    <div class="form-row">
      <div class="form-group col-md-6">
        <label for="inv_image">Main Image</label>
        <input type="file" id="inv_image" name="inv_image" class="form-control-file">
        <% if (locals.formData && locals.formData.inv_image) { %>
          <small class="form-text text-muted">
            Current: <%= locals.formData.inv_image %>
          </small>
        <% } %>
      </div>
      <div class="form-group col-md-6">
        <label for="inv_thumbnail">Thumbnail</label>
        <input type="file" id="inv_thumbnail" name="inv_thumbnail" class="form-control-file">
        <% if (locals.formData && locals.formData.inv_thumbnail) { %>
          <small class="form-text text-muted">
            Current: <%= locals.formData.inv_thumbnail %>
          </small>
        <% } %>
      </div>
    </div>

    <!-- Description -->
    <div class="form-group">
      <label for="inv_description">Description</label>
      <textarea id="inv_description" name="inv_description" class="form-control" rows="4"><%= (locals.formData && locals.formData.inv_description) || '' %></textarea>
    </div>

    <!-- Form Actions -->
    <div class="form-actions mt-4">
      <a href="/inv" class="btn btn-secondary">
        <i class="fas fa-times"></i> Cancel
      </a>
      <button type="submit" class="btn btn-primary">
        <i class="fas fa-save"></i> Save Vehicle
      </button>
    </div>
  </form>
</main>

<%- include('../partials/footer') %>